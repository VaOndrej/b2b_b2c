// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model MarginGuardConfig {
  id                    String   @id @default("default")
  b2bTag                String   @default("b2b")
  globalMinPricePercent Float    @default(70)
  b2bGlobalMinPricePercent Float  @default(70)
  productCatalogSourceType String @default("SHOPIFY")
  productCatalogAutoImportEnabled Boolean @default(true)
  productCatalogLastSyncAt DateTime?
  productCatalogLastSyncError String?
  allowZeroFinalPrice   Boolean  @default(false)
  allowRemoveAtMinimumOrderQuantity Boolean @default(true)
  allowStacking         Boolean  @default(false)
  maxCombinedPercentOff Float?
  cartValidationStatus  String   @default("UNKNOWN")
  cartValidationLastError String?
  cartValidationLastSyncAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  productFloors         ProductFloorRule[]
  productTierPrices     ProductTierPriceRule[]
  productQuantityRules  ProductQuantityRule[]
  collectionQuantityRules CollectionQuantityRule[]
  productCustomerQuantityRules ProductCustomerQuantityRule[]
  productVisibilityRules ProductVisibilityRule[]
  productVariantVisibilityRules ProductVariantVisibilityRule[]
  couponSegmentRules    CouponSegmentRule[]
  discountRules         DiscountRule[]
  discountCombinationBlacklistRules DiscountCombinationBlacklistRule[]
  discountSegmentCaps   DiscountSegmentCap[]
  violations            MarginViolationLog[]
  storefrontContentRules StorefrontContentRule[]
  collectionVisibilityRules CollectionVisibilityRule[]
}

model CatalogProduct {
  id              String   @id @default(cuid())
  sourceType      String
  externalKey     String
  shopifyProductId String? @unique
  title           String
  handle          String?
  status          String?
  vendor          String?
  productType     String?
  imageUrl        String?
  isActive        Boolean  @default(true)
  syncedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sourceType, externalKey])
}

model CatalogCollection {
  id                  String   @id @default(cuid())
  sourceType          String
  externalKey         String
  shopifyCollectionId String?  @unique
  title               String
  handle              String?
  isActive            Boolean  @default(true)
  syncedAt            DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([sourceType, externalKey])
}

model CatalogVariant {
  id               String   @id @default(cuid())
  sourceType       String
  externalKey      String
  shopifyVariantId String?  @unique
  shopifyProductId String?
  title            String
  productTitle     String
  productHandle    String?
  sku              String?
  optionSummary    String?
  isActive         Boolean  @default(true)
  syncedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([sourceType, externalKey])
}

model ProductFloorRule {
  id                    String            @id @default(cuid())
  configId              String
  config                MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  productId             String
  segment               String?
  minPercentOfBasePrice Float
  allowZeroFinalPrice   Boolean?
  b2bOverridePrice      Float?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@unique([configId, productId, segment])
}

model ProductTierPriceRule {
  id         String            @id @default(cuid())
  configId   String
  config     MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  productId  String
  segment    String?
  minQuantity Int
  unitPrice  Float
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([configId, productId, segment, minQuantity])
}

model ProductQuantityRule {
  id                   String            @id @default(cuid())
  configId             String
  config               MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  productId            String
  segment              String?
  minimumOrderQuantity Int
  stepQuantity         Int?
  maxOrderQuantity     Int?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@unique([configId, productId, segment])
}

model ProductCustomerQuantityRule {
  id               String            @id @default(cuid())
  configId         String
  config           MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  productId        String
  customerId       String
  maxOrderQuantity Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([configId, productId, customerId])
}

model CollectionQuantityRule {
  id               String            @id @default(cuid())
  configId         String
  config           MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  collectionId     String
  segment          String?
  maxOrderQuantity Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([configId, collectionId, segment])
}

model ProductVisibilityRule {
  id             String            @id @default(cuid())
  configId       String
  config         MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  productId      String
  visibilityMode String
  customerId     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([configId, productId])
}

model ProductVariantVisibilityRule {
  id             String            @id @default(cuid())
  configId       String
  config         MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  productId      String
  variantId      String
  visibilityMode String
  customerId     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([configId, variantId])
}

model CouponSegmentRule {
  id             String            @id @default(cuid())
  configId       String
  config         MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  code           String
  allowedSegment String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([configId, code])
}

model DiscountRule {
  id                       String            @id @default(cuid())
  configId                 String
  config                   MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  scope                    String
  canonicalKey             String
  targetId                 String?
  code                     String?
  segment                  String?
  percentOff               Float
  priority                 Int               @default(100)
  stackMode                String            @default("STACKABLE")
  minPricePercentOfBasePrice Float?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  @@unique([configId, canonicalKey])
}

model DiscountCombinationBlacklistRule {
  id         String            @id @default(cuid())
  configId   String
  config     MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  canonicalPairKey String
  leftType   String
  leftValue  String
  rightType  String
  rightValue String
  segment    String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([configId, canonicalPairKey])
}

model DiscountSegmentCap {
  id                    String            @id @default(cuid())
  configId              String
  config                MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  segment               String
  maxCombinedPercentOff Float
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@unique([configId, segment])
}

model MarginViolationLog {
  id              String            @id @default(cuid())
  configId        String
  config          MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  shop            String
  productId       String
  customerId      String?
  segment         String
  basePrice       Float
  finalPrice      Float
  floorPrice      Float
  violationAmount Float
  source          String
  createdAt       DateTime          @default(now())
}

model StorefrontContentRule {
  id              String            @id @default(cuid())
  configId        String
  config          MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  name            String
  active          Boolean           @default(true)
  priority        Int               @default(100)
  segment         String
  pageType        String            @default("ALL")
  productId       String?
  collectionId    String?
  targetType      String
  targetSelector  String?
  targetPosition  String?
  action          String
  value           String?
  valueCsLocale   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([configId, name])
}

model CollectionVisibilityRule {
  id               String            @id @default(cuid())
  configId         String
  config           MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  collectionId     String
  collectionHandle String
  collectionTitle  String?
  visibilityMode   String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([configId, collectionId])
}
