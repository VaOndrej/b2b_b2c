// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model MarginGuardConfig {
  id                    String   @id @default("default")
  b2bTag                String   @default("b2b")
  globalMinPricePercent Float    @default(70)
  allowZeroFinalPrice   Boolean  @default(false)
  allowStacking         Boolean  @default(false)
  maxCombinedPercentOff Float?
  cartValidationStatus  String   @default("UNKNOWN")
  cartValidationLastError String?
  cartValidationLastSyncAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  productFloors         ProductFloorRule[]
  violations            MarginViolationLog[]
}

model ProductFloorRule {
  id                    String            @id @default(cuid())
  configId              String
  config                MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  productId             String
  segment               String?
  minPercentOfBasePrice Float
  allowZeroFinalPrice   Boolean?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@unique([configId, productId, segment])
}

model MarginViolationLog {
  id              String            @id @default(cuid())
  configId        String
  config          MarginGuardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  shop            String
  productId       String
  customerId      String?
  segment         String
  basePrice       Float
  finalPrice      Float
  floorPrice      Float
  violationAmount Float
  source          String
  createdAt       DateTime          @default(now())
}
